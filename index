<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>SQV Chronicles — The Qualification Visit</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#0a1628;--bg2:#0f1e35;--bg3:#162540;
  --accent:#4cc9f0;--accent2:#06d6a0;--warn:#ffd166;--danger:#ef476f;
  --text:#e8f4f8;--muted:#7a9ab0;--border:rgba(76,201,240,0.12);
  --card:rgba(15,30,53,0.9);--font:'Segoe UI',system-ui,sans-serif;
}
body{background:var(--bg);font-family:var(--font);color:var(--text);min-height:100vh;overflow:hidden;}
.screen{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;z-index:10;}
.hidden{display:none!important;}

/* ── LOGIN ── */
#s-login{background:var(--bg);flex-direction:column;align-items:center;}
.login-brand{text-align:center;margin-bottom:28px;}
.login-badge{font-size:10px;letter-spacing:4px;color:var(--accent);opacity:.7;text-transform:uppercase;margin-bottom:8px;}
.login-title{font-size:34px;font-weight:800;color:#fff;letter-spacing:-1px;}
.login-sub{font-size:12px;color:var(--muted);letter-spacing:2px;margin-top:4px;}
.login-box{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:28px 32px;width:360px;display:flex;flex-direction:column;gap:14px;}
.login-tabs{display:flex;gap:0;border:1px solid var(--border);border-radius:8px;overflow:hidden;margin-bottom:4px;}
.ltab{flex:1;padding:9px 0;text-align:center;font-size:12px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;color:var(--muted);background:transparent;border:none;transition:all .2s;}
.ltab.active{background:var(--accent);color:#0a1628;font-weight:700;}
.login-label{font-size:11px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;}
.login-input{width:100%;padding:10px 14px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:14px;outline:none;transition:border .2s;}
.login-input:focus{border-color:var(--accent);}
.login-err{font-size:12px;color:var(--danger);text-align:center;min-height:16px;}
.btn-primary{width:100%;padding:12px;background:var(--accent2);border:none;border-radius:6px;color:#0a1628;font-size:13px;font-weight:800;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .2s;}
.btn-primary:hover{filter:brightness(1.12);transform:scale(1.02);}
.lang-row{display:flex;gap:8px;}
.lang-btn{flex:1;padding:9px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:6px;color:var(--muted);font-size:12px;font-weight:600;letter-spacing:1px;cursor:pointer;text-align:center;transition:all .2s;}
.lang-btn.sel{background:rgba(76,201,240,0.15);border-color:var(--accent);color:var(--accent);}
.login-note{font-size:11px;color:var(--muted);text-align:center;opacity:.6;}

/* ── ADMIN DASHBOARD ── */
#s-admin{background:var(--bg);flex-direction:column;padding:32px;overflow-y:auto;align-items:flex-start;justify-content:flex-start;}
.adm-header{display:flex;align-items:center;justify-content:space-between;width:100%;max-width:700px;margin:0 auto 24px;}
.adm-title{font-size:22px;font-weight:700;}
.adm-badge{font-size:10px;letter-spacing:3px;color:var(--accent);text-transform:uppercase;}
.btn-sm{padding:7px 18px;background:transparent;border:1px solid var(--border);border-radius:6px;color:var(--muted);font-size:11px;letter-spacing:1px;cursor:pointer;transition:all .2s;}
.btn-sm:hover{border-color:var(--accent);color:var(--accent);}
.lb-table{width:100%;max-width:700px;margin:0 auto;border-collapse:collapse;}
.lb-table th{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);padding:8px 12px;text-align:left;border-bottom:1px solid var(--border);}
.lb-table td{padding:12px;border-bottom:1px solid rgba(76,201,240,0.06);font-size:14px;}
.lb-rank{font-weight:800;color:var(--muted);font-size:13px;}
.lb-rank.r1{color:#ffd700;}
.lb-rank.r2{color:#c0c0c0;}
.lb-rank.r3{color:#cd7f32;}
.lb-score{font-weight:700;}
.sc-ok{color:var(--accent2);}
.sc-cond{color:var(--warn);}
.sc-no{color:var(--danger);}
.lb-verdict{font-size:11px;letter-spacing:1px;}
.lb-empty{text-align:center;padding:40px;color:var(--muted);font-size:14px;}
.lb-bar{height:4px;background:rgba(76,201,240,0.1);border-radius:2px;margin-top:4px;overflow:hidden;}
.lb-bar-fill{height:100%;border-radius:2px;transition:width 1s ease;}

/* ── GAME ── */
#s-game{background:var(--bg);flex-direction:column;padding:0;overflow:hidden;align-items:stretch;justify-content:flex-start;}
#g-hud{display:flex;align-items:center;justify-content:space-between;padding:8px 16px;background:rgba(5,12,24,.97);border-bottom:1px solid var(--border);flex-shrink:0;font-size:12px;}
#g-hud-score{color:var(--accent);letter-spacing:2px;font-weight:700;}
#g-hud-area{color:var(--muted);letter-spacing:1px;font-size:11px;}
.g-dots{display:flex;gap:5px;}
.g-dot{width:7px;height:7px;border-radius:50%;background:rgba(76,201,240,.1);transition:background .3s;}
.g-dot.done{background:var(--accent2);}
.g-dot.active{background:var(--accent);}
#g-lang-btn{background:none;border:1px solid var(--border);color:var(--muted);padding:3px 10px;border-radius:12px;cursor:pointer;font-size:11px;letter-spacing:1px;transition:all .2s;}
#g-lang-btn:hover{border-color:var(--accent);color:var(--accent);}
#g-scene{flex:1;position:relative;overflow:hidden;display:flex;align-items:flex-end;justify-content:center;}
.g-bg{position:absolute;inset:0;transition:background .6s;}
.bg-brief{background:#0d1b2a;} .bg-office{background:#1a1208;}
.bg-docs{background:#0e1a2e;} .bg-pharm{background:#071a26;}
.bg-isf{background:#1a1610;} .bg-lab{background:#081a12;}
.bg-emr{background:#0a1020;} .bg-coi{background:#1a0e18;}
.bg-report{background:#0a1628;}
.g-room-canvas{position:absolute;inset:0;pointer-events:none;opacity:.3;}
#g-char{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:160px;height:240px;transition:opacity .4s;}
#g-dialog{background:rgba(8,18,34,.97);border-top:1px solid var(--border);padding:14px 18px 38px;flex-shrink:0;min-height:128px;position:relative;cursor:pointer;}
.g-speaker{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;}
.sp-narrator{color:var(--muted);font-style:italic;}
.sp-you{color:var(--accent2);}
.sp-pi{color:var(--warn);}
.sp-manager,.sp-lsm{color:#4cc9f0;}
.sp-pharmacist{color:#a8e6cf;}
.sp-coordinator{color:#ffc8dd;}
.sp-labtech{color:#c3b1e1;}
.sp-pi2{color:#ffa07a;}
.g-dtext{font-size:15px;line-height:1.65;color:var(--text);min-height:46px;}
#g-cont{position:absolute;bottom:10px;right:16px;background:none;border:none;color:rgba(76,201,240,.45);font-size:12px;cursor:pointer;animation:blink 1.5s infinite;padding:0;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}
#g-choices{display:none;flex-direction:column;gap:8px;padding:12px 16px;background:rgba(8,18,34,.97);border-top:1px solid var(--border);flex-shrink:0;}
.g-cprompt{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--warn);margin-bottom:4px;}
.g-cbtn{background:rgba(30,45,64,.8);border:1px solid var(--border);color:var(--text);padding:10px 14px;border-radius:6px;cursor:pointer;font-size:13px;text-align:left;transition:all .2s;line-height:1.4;}
.g-cbtn:hover{background:rgba(76,201,240,.1);border-color:var(--accent);transform:translateX(3px);}
#g-conseq{display:none;flex-direction:column;padding:12px 16px;background:rgba(8,18,34,.97);border-top:1px solid var(--border);flex-shrink:0;}
.g-ctext{font-size:13px;line-height:1.6;padding:10px 13px;border-radius:6px;margin-bottom:10px;}
.cok{background:rgba(6,214,160,.1);border:1px solid rgba(6,214,160,.3);color:#a8f0d8;}
.cbad{background:rgba(239,71,111,.1);border:1px solid rgba(239,71,111,.3);color:#f5a8bc;}
.cpart{background:rgba(255,209,102,.1);border:1px solid rgba(255,209,102,.3);color:#ffe8a0;}
#g-nxtbtn{align-self:flex-start;padding:8px 22px;background:var(--accent);border:none;border-radius:4px;color:#0a1628;font-size:12px;font-weight:700;letter-spacing:1px;cursor:pointer;transition:all .2s;}
#g-nxtbtn:hover{background:#7dd8f8;}

/* ── FINAL ── */
#g-final{display:none;position:absolute;inset:0;background:var(--bg);overflow-y:auto;padding:24px;z-index:15;}
.f-verdict{font-size:26px;font-weight:800;margin-bottom:4px;}
.vok{color:var(--accent2);}
.vcond{color:var(--warn);}
.vno{color:var(--danger);}
.f-score{font-size:14px;color:var(--muted);margin-bottom:6px;}
.f-bar{width:100%;height:6px;background:rgba(30,45,64,.8);border-radius:3px;margin:12px 0;overflow:hidden;}
.f-bar-fill{height:100%;border-radius:3px;transition:width 1.2s ease;}
.f-note{font-size:12px;color:var(--muted);line-height:1.6;max-width:460px;margin-bottom:18px;}
.f-dtitle{font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:10px;text-align:center;}
.f-ditem{background:rgba(30,45,64,.5);border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:10px;display:grid;grid-template-columns:28px 1fr;gap:10px;}
.f-dicon{font-size:18px;padding-top:2px;}
.f-darea{font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:3px;}
.f-dchoice{font-size:12px;color:var(--text);margin-bottom:4px;font-style:italic;}
.f-dexp{font-size:11px;line-height:1.5;color:var(--muted);}
.f-dpts{font-size:11px;font-weight:700;margin-top:4px;}
.pts-ok{color:var(--accent2);}
.pts-no{color:var(--danger);}
.pts-p{color:var(--warn);}
.f-actions{display:flex;gap:10px;margin-top:20px;flex-wrap:wrap;}
.btn-ghost{padding:9px 24px;background:rgba(30,45,64,.8);border:1px solid var(--border);color:var(--text);border-radius:6px;cursor:pointer;font-size:12px;letter-spacing:1.5px;transition:all .2s;}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent);}
</style>
</head>
<body>

<!-- ═══════════════ LOGIN SCREEN ═══════════════ -->
<div id="s-login" class="screen">
  <div class="login-brand">
    <div class="login-badge">Clinical Trial Simulation</div>
    <div class="login-title">SQV Chronicles</div>
    <div class="login-sub">The Qualification Visit · Estudio X</div>
  </div>
  <div class="login-box">
    <div class="login-tabs">
      <button class="ltab active" onclick="L.tab('player')">Jugador / Player</button>
      <button class="ltab" onclick="L.tab('admin')">Admin</button>
    </div>

    <div id="l-player-section">
      <div class="login-label" id="l-name-label">Tu nombre / Your name</div>
      <input class="login-input" id="l-name" type="text" placeholder="Ej: María González" maxlength="32"/>
      <div class="login-label" id="l-lang-label">Idioma / Language</div>
      <div class="lang-row">
        <button class="lang-btn sel" id="lb-es" onclick="L.lang('es')">🇦🇷 Español</button>
        <button class="lang-btn" id="lb-en" onclick="L.lang('en')">🇺🇸 English</button>
      </div>
      <button class="btn-primary" onclick="L.startPlayer()">▶ COMENZAR MISIÓN</button>
      <div class="login-note" id="l-note">Ingresá tu nombre para guardar tu puntaje</div>
    </div>

    <div id="l-admin-section" class="hidden">
      <div class="login-label">Usuario</div>
      <input class="login-input" id="l-adm-user" type="text" placeholder="admin"/>
      <div class="login-label">Contraseña</div>
      <input class="login-input" id="l-adm-pass" type="password" placeholder="••••"/>
      <div class="login-err" id="l-err"></div>
      <button class="btn-primary" onclick="L.loginAdmin()">INGRESAR</button>
    </div>
  </div>
</div>

<!-- ═══════════════ ADMIN DASHBOARD ═══════════════ -->
<div id="s-admin" class="screen hidden">
  <div class="adm-header">
    <div>
      <div class="adm-badge">Panel de Administrador</div>
      <div class="adm-title">🏆 Leaderboard — Estudio X SQV</div>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn-sm" onclick="A.refresh()">↻ Actualizar</button>
      <button class="btn-sm" onclick="A.clear()">🗑 Limpiar</button>
      <button class="btn-sm" onclick="A.logout()">← Salir</button>
    </div>
  </div>
  <table class="lb-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Nombre / Name</th>
        <th>Puntaje / Score</th>
        <th>Veredicto / Verdict</th>
        <th>Fecha / Date</th>
      </tr>
    </thead>
    <tbody id="lb-body">
      <tr><td colspan="5" class="lb-empty">Cargando...</td></tr>
    </tbody>
  </table>
</div>

<!-- ═══════════════ GAME SCREEN ═══════════════ -->
<div id="s-game" class="screen hidden">
  <div id="g-hud">
    <div id="g-hud-score">SCORE: 0 / 100</div>
    <div class="g-dots" id="g-dots"></div>
    <div id="g-hud-area"></div>
    <button id="g-lang-btn" onclick="G.toggleLang()">EN</button>
  </div>
  <div id="g-scene">
    <div class="g-bg bg-brief" id="g-bg">
      <canvas class="g-room-canvas" id="g-deco"></canvas>
    </div>
    <div id="g-char"></div>
    <div id="g-final"></div>
  </div>
  <div id="g-dialog">
    <div class="g-speaker" id="g-spk"></div>
    <div class="g-dtext" id="g-dtxt"></div>
    <button id="g-cont">▶ Continuar</button>
  </div>
  <div id="g-choices">
    <div class="g-cprompt" id="g-cpr"></div>
    <div id="g-cbtns"></div>
  </div>
  <div id="g-conseq">
    <div class="g-ctext" id="g-ctxt"></div>
    <button id="g-nxtbtn" onclick="G.nextScene()"></button>
  </div>
</div>

<script>
// ─── STORAGE (leaderboard) ───────────────────────────────────
const LS_KEY='sqv-leaderboard';
function lbLoad(){try{const d=localStorage.getItem(LS_KEY);return d?JSON.parse(d):[]}catch{return[]}}
function lbSave(data){try{localStorage.setItem(LS_KEY,JSON.stringify(data))}catch{}}
function lbAdd(name,score,lang){
  const lb=lbLoad();
  lb.push({name,score,lang,date:new Date().toLocaleDateString()});
  lb.sort((a,b)=>b.score-a.score);
  lbSave(lb.slice(0,50));
}

